{
  "name": "@hope/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "wrangler dev",
    "dev:node": "tsx --watch src/serve.ts",
    "start": "tsx src/serve.ts",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "dump-openapi": "tsx scripts/dump-openapi.ts",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1088.0",
    "@clerk/backend": "^3.11.6",
    "@hono/node-server": "^2.0.10",
    "@hono/standard-validator": "^0.2.3",
    "@hope/core": "workspace:*",
    "@hope/db": "workspace:*",
    "@hope/shared": "workspace:*",
    "@scalar/hono-api-reference": "^0.11.10",
    "@standard-community/standard-json": "^0.3.5",
    "@standard-community/standard-openapi": "^0.2.9",
    "@types/json-schema": "^7.0.15",
    "hono": "^4.12.30",
    "hono-openapi": "^1.3.1",
    "openapi-types": "^12.1.3",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260716.1",
    "@types/node": "^26.1.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "wrangler": "^4.111.0"
  }
}
