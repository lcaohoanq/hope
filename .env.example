# --- Clerk ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Disable Clerk keyless fallback (prevents auth loops when real keys are set)
NEXT_PUBLIC_CLERK_KEYLESS_DISABLED=1
# Svix signing secret from Clerk Dashboard → Webhooks (billing lifecycle sync)
CLERK_WEBHOOK_SIGNING_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# --- Web (apps/web) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8787
API_URL=http://localhost:8787
NEXT_PUBLIC_ENABLE_ERUDA=false

# --- Database ---
DATABASE_URL=
DIRECT_URL=

# --- Storage ---
# "minio" or "cloudinary" (default: cloudinary)
STORAGE_PROVIDER=cloudinary

# Cloudinary (when STORAGE_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# MinIO (when STORAGE_PROVIDER=minio — auto-configured in Docker)
# MINIO_ENDPOINT=http://minio:9000
# MINIO_ACCESS_KEY=hope
# MINIO_SECRET_KEY=hope_local_pw
# MINIO_BUCKET=hope
# STORAGE_PUBLIC_URL=http://localhost/api/storage

# --- Cron / Email ---
RESEND_API_KEY=
RESEND_FROM=Hope <onboarding@resend.dev>
TIMEZONE=Asia/Ho_Chi_Minh

# --- Optional legacy GitHub JSON storage ---
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main
WORKOUT_DATA_PATH=data/workouts.json
