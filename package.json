{
  "name": "hope-monorepo",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "biome lint .",
    "lint:write": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "setup": "tsx scripts/setup.ts setup",
    "hope": "tsx scripts/setup.ts",
    "up": "tsx scripts/setup.ts up",
    "down": "tsx scripts/setup.ts down",
    "status": "tsx scripts/setup.ts status",
    "docs:dev": "pnpm --filter @hope/docs dev",
    "docs:build": "pnpm --filter @hope/docs build",
    "mobile": "pnpm --filter @hope/mobile start",
    "mobile:android": "pnpm --filter @hope/mobile android",
    "mobile:ios": "pnpm --filter @hope/mobile ios",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@types/inquirer": "^9.0.10",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "inquirer": "^14.0.2",
    "lefthook": "2.1.10",
    "ora": "^9.4.1",
    "tsx": "^4.23.1",
    "turbo": "^2.10.6"
  }
}
